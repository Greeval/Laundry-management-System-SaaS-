<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Menunggu Pembayaran</h1>
    </div>

    <% if (pendingPayments.length === 0) { %>
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="bi bi-check2-circle display-1 text-success mb-3 d-block"></i>
                <h4 class="text-muted">Semua pembayaran sudah lunas</h4>
                <p class="text-muted mb-0">Tidak ada tagihan yang menunggu konfirmasi saat ini.</p>
            </div>
        </div>
    <% } else { %>
        <div class="row g-4">
            <% pendingPayments.forEach(payment => { %>
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm border-0 h-100 border-top border-warning border-4">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-3">
                                <span class="badge bg-warning text-dark">Menunggu</span>
                                <small class="text-muted"><%= new Date(payment.order.createdAt).toLocaleDateString('id-ID') %></small>
                            </div>
                            
                            <h5 class="fw-bold mb-1">
                                <a href="/orders/<%= payment.order.id %>" class="text-decoration-none text-dark">
                                    #<%= payment.order.order_code %>
                                </a>
                            </h5>
                            <p class="text-muted mb-3"><i class="bi bi-person"></i> <%= payment.order.customer.name %></p>

                            <div class="bg-light p-3 rounded mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <small class="text-muted text-uppercase"><%= payment.method %></small>
                                    <small class="text-muted">Tagihan: Rp <%= payment.base_amount.toLocaleString('id-ID') %></small>
                                </div>
                                <% if (payment.method !== 'cash') { %>
                                <div class="d-flex justify-content-between mb-1">
                                    <small class="text-muted">Kode Unik</small>
                                    <small class="text-warning fw-bold">+<%= payment.unique_code %></small>
                                </div>
                                <% } %>
                                <hr class="my-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold">Total Transfer</span>
                                    <span class="fw-bold fs-5 text-primary">Rp <%= payment.expected_amount.toLocaleString('id-ID') %></span>
                                </div>
                            </div>

                            <% if (payment.proof_image_url) { %>
                                <div class="mb-3">
                                    <a href="<%= payment.proof_image_url %>" target="_blank" class="btn btn-sm btn-outline-info w-100">
                                        <i class="bi bi-image"></i> Lihat Bukti Transfer
                                    </a>
                                </div>
                            <% } %>

                            <form action="/payments/<%= payment.id %>/approve" method="POST">
                                <button type="submit" class="btn btn-success w-100 fw-bold" onclick="return confirm('Apakah Anda yakin dana sebesar Rp <%= payment.expected_amount.toLocaleString('id-ID') %> sudah masuk ke rekening?')">
                                    <i class="bi bi-check-circle"></i> Approve Lunas
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>
