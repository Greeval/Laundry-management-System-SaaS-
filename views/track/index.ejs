<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>Laundry Tracker</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="/css/output.css" rel="stylesheet">
</head>
<body class="bg-surface font-sans text-on-surface antialiased min-h-screen flex flex-col">

    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-outline/30 sticky top-0 z-50">
        <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
            <a href="/track" class="flex items-center gap-2 text-primary">
                <i class="bi bi-droplet-fill text-2xl"></i>
                <span class="font-bold text-xl tracking-tight">Laundry Tracker</span>
            </a>
            <a href="/login" class="text-sm font-medium text-on-surface-variant hover:text-primary transition-colors">Masuk Mitra</a>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col items-center justify-center p-4">
        <div class="w-full max-w-xl">
            
            <div class="text-center mb-8">
                <h1 class="text-3xl font-extrabold text-on-surface mb-2">Lacak Pesanan Anda</h1>
                <p class="text-on-surface-variant">Masukkan kode resi (kode pesanan) yang diberikan oleh pihak laundry.</p>
            </div>

            <!-- Search Box -->
            <div class="bg-white rounded-2xl shadow-lg border border-outline/20 p-6 mb-8">
                <form action="/track" method="GET" class="flex flex-col sm:flex-row gap-3">
                    <div class="relative flex-grow">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="bi bi-search text-on-surface-variant"></i>
                        </div>
                        <input type="text" name="code" value="<%= code %>" placeholder="Contoh: ORD-123456" required class="w-full pl-11 pr-4 py-3 rounded-xl border border-outline/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-on-surface font-medium text-lg uppercase transition-all">
                    </div>
                    <button type="submit" class="px-8 py-3 rounded-xl bg-primary text-white font-bold hover:bg-primary/90 shadow-md transition-all active:scale-95 whitespace-nowrap">
                        Cari Resi
                    </button>
                </form>
                
                <% if (messages.error && messages.error.length > 0) { %>
                    <div class="mt-4 p-3 bg-red-50 text-red-600 rounded-lg text-sm border border-red-100 flex items-center gap-2">
                        <i class="bi bi-exclamation-circle-fill"></i> <%= messages.error[0] %>
                    </div>
                <% } %>
            </div>

            <!-- Result Area -->
            <% if (code && !order) { %>
                <div class="text-center p-8 bg-white rounded-2xl border border-dashed border-outline text-on-surface-variant">
                    <i class="bi bi-search-heart text-4xl mb-3 text-outline"></i>
                    <p class="font-medium">Pesanan dengan kode <strong class="text-on-surface">"<%= code %>"</strong> tidak ditemukan.</p>
                    <p class="text-sm mt-1">Pastikan kode yang dimasukkan benar.</p>
                </div>
            <% } else if (order) { %>
                <div class="bg-white rounded-2xl shadow-lg border border-outline/20 overflow-hidden">
                    <!-- Receipt Header -->
                    <div class="bg-primary text-white p-6 relative overflow-hidden">
                        <div class="absolute top-0 right-0 p-4 opacity-10">
                            <i class="bi bi-receipt text-8xl"></i>
                        </div>
                        <div class="relative z-10">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <p class="text-primary-container text-sm font-medium mb-1">KODE PESANAN</p>
                                    <h2 class="text-3xl font-extrabold tracking-wider"><%= order.order_code %></h2>
                                </div>
                                <div class="text-right">
                                    <p class="text-primary-container text-sm font-medium mb-1">TANGGAL</p>
                                    <p class="font-semibold"><%= order.createdAt.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                                </div>
                            </div>
                            
                            <div class="inline-block mt-2 px-4 py-1.5 rounded-full text-sm font-bold bg-white/20 backdrop-blur-sm border border-white/30">
                                <% if (order.status === 'menunggu') { %>
                                    <i class="bi bi-hourglass-split mr-1"></i> Menunggu Diproses
                                <% } else if (order.status === 'diproses') { %>
                                    <i class="bi bi-arrow-repeat mr-1"></i> Sedang Diproses (Dicuci)
                                <% } else if (order.status === 'selesai') { %>
                                    <i class="bi bi-check-circle mr-1"></i> Selesai & Siap Diambil
                                <% } else if (order.status === 'diambil') { %>
                                    <i class="bi bi-bag-check-fill mr-1"></i> Sudah Diambil
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Receipt Body -->
                    <div class="p-6">
                        <div class="grid grid-cols-2 gap-y-6 gap-x-4 mb-6">
                            <div>
                                <p class="text-xs text-on-surface-variant font-medium uppercase tracking-wider mb-1">Laundry Outlet</p>
                                <p class="font-semibold text-on-surface"><%= order.tenant.name %></p>
                            </div>
                            <div>
                                <p class="text-xs text-on-surface-variant font-medium uppercase tracking-wider mb-1">Pelanggan</p>
                                <p class="font-semibold text-on-surface"><%= order.customer.name %></p>
                            </div>
                            <div>
                                <p class="text-xs text-on-surface-variant font-medium uppercase tracking-wider mb-1">Layanan</p>
                                <% const svc = h.getServiceDetails(order.service_type); %>
                                <p class="font-semibold text-on-surface capitalize"><%= svc.name %></p>
                            </div>
                            <div>
                                <p class="text-xs text-on-surface-variant font-medium uppercase tracking-wider mb-1">Berat</p>
                                <p class="font-semibold text-on-surface"><%= order.weight_kg ? order.weight_kg + ' Kg' : '-' %></p>
                            </div>
                        </div>

                        <hr class="border-outline/30 mb-6 border-dashed">

                        <!-- Payment & Total -->
                        <div class="bg-surface-container rounded-xl p-4">
                            <p class="text-xs text-on-surface-variant font-medium uppercase tracking-wider mb-2">Informasi Pembayaran</p>
                            <div class="flex justify-between items-center mb-1">
                                <span class="text-on-surface">Total Tagihan</span>
                                <span class="font-bold text-lg">Rp <%= order.price_total ? Number(order.price_total).toLocaleString('id-ID') : '0' %></span>
                            </div>
                            
                            <% if (order.payment) { %>
                                <div class="flex justify-between items-center mt-2 pt-2 border-t border-outline/20 text-sm">
                                    <span class="text-on-surface-variant">Status Pembayaran</span>
                                    <% if (order.payment.status === 'paid') { %>
                                        <span class="text-green-600 font-bold flex items-center gap-1"><i class="bi bi-check-circle-fill"></i> LUNAS</span>
                                    <% } else { %>
                                        <span class="text-amber-600 font-bold flex items-center gap-1"><i class="bi bi-clock-fill"></i> BELUM LUNAS</span>
                                    <% } %>
                                </div>
                            <% } else { %>
                                <div class="flex justify-between items-center mt-2 pt-2 border-t border-outline/20 text-sm">
                                    <span class="text-on-surface-variant">Status Pembayaran</span>
                                    <span class="text-on-surface-variant font-medium italic">Belum tersedia</span>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% } %>

        </div>
    </main>

    <footer class="py-6 text-center text-on-surface-variant text-sm border-t border-outline/20 bg-white">
        &copy; 2026 Laundry Management System.
    </footer>

</body>
</html>
