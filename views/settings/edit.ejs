<div class="py-4 max-w-4xl mx-auto">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-on-surface">Pengaturan</h1>
    </div>

    <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/30">
        <div class="p-6 sm:p-8">
            <form action="/settings" method="POST" enctype="multipart/form-data" class="space-y-8">
                
                <!-- Integrasi WhatsApp (Fonnte) -->
                <div>
                    <h5 class="text-lg font-bold text-primary border-b border-outline-variant/30 pb-3 mb-6">Integrasi WhatsApp (Fonnte API)</h5>
                    
                    <div>
                        <label for="fonnte_token" class="block font-medium text-on-surface mb-2">Fonnte API Token</label>
                        <p class="text-sm text-on-surface-variant mb-3">Dapatkan token API Anda dengan mendaftar di <a href="https://fonnte.com/" target="_blank" class="text-primary hover:underline">fonnte.com</a>. Token ini digunakan untuk mengirim notifikasi WhatsApp ke pelanggan Anda secara otomatis tanpa perlu scan QR di server.</p>
                        <input type="text" id="fonnte_token" name="fonnte_token" value="<%= settings.fonnte_token || '' %>" placeholder="Contoh: ABCD1234EFGH5678" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
                    </div>
                </div>

                <!-- Informasi Usaha -->
                <div>
                    <h5 class="text-lg font-bold text-primary border-b border-outline-variant/30 pb-3 mb-6">Informasi Usaha</h5>
                    
                    <div>
                        <label for="business_name" class="block font-medium text-on-surface mb-2">Nama Laundry <span class="text-error">*</span></label>
                        <input type="text" id="business_name" name="business_name" value="<%= settings.business_name %>" required class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
                    </div>
                </div>

                <!-- Pengaturan Tarif -->
                <div>
                    <h5 class="text-lg font-bold text-primary border-b border-outline-variant/30 pb-3 mb-6">Pengaturan Tarif</h5>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label for="price_per_kg" class="block font-medium text-on-surface mb-2">Tarif Reguler / Kg (Rp) <span class="text-error">*</span></label>
                            <div class="flex">
                                <span class="inline-flex items-center px-4 py-3 rounded-l-xl border border-r-0 border-outline-variant/50 bg-surface-container-highest text-on-surface-variant font-medium">Rp</span>
                                <input type="number" id="price_per_kg" name="price_per_kg" value="<%= settings.price_per_kg %>" required class="w-full px-4 py-3 rounded-r-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
                            </div>
                        </div>
                        <div>
                            <label for="express_price_per_kg" class="block font-medium text-on-surface mb-2">Tarif Express / Kg (Rp)</label>
                            <div class="flex">
                                <span class="inline-flex items-center px-4 py-3 rounded-l-xl border border-r-0 border-outline-variant/50 bg-surface-container-highest text-on-surface-variant font-medium">Rp</span>
                                <input type="number" id="express_price_per_kg" name="express_price_per_kg" value="<%= settings.express_price_per_kg %>" class="w-full px-4 py-3 rounded-r-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
                            </div>
                        </div>
                        <div>
                            <label for="cuci_price_per_kg" class="block font-medium text-on-surface mb-2">Tarif Cuci (Saja) / Kg (Rp)</label>
                            <div class="flex">
                                <span class="inline-flex items-center px-4 py-3 rounded-l-xl border border-r-0 border-outline-variant/50 bg-surface-container-highest text-on-surface-variant font-medium">Rp</span>
                                <input type="number" id="cuci_price_per_kg" name="cuci_price_per_kg" value="<%= settings.cuci_price_per_kg || 0 %>" class="w-full px-4 py-3 rounded-r-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
                            </div>
                        </div>
                        <div>
                            <label for="cuci_kering_price_per_kg" class="block font-medium text-on-surface mb-2">Tarif Cuci Kering / Kg (Rp)</label>
                            <div class="flex">
                                <span class="inline-flex items-center px-4 py-3 rounded-l-xl border border-r-0 border-outline-variant/50 bg-surface-container-highest text-on-surface-variant font-medium">Rp</span>
                                <input type="number" id="cuci_kering_price_per_kg" name="cuci_kering_price_per_kg" value="<%= settings.cuci_kering_price_per_kg || 0 %>" class="w-full px-4 py-3 rounded-r-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
                            </div>
                        </div>
                        <div>
                            <label for="cuci_setrika_price_per_kg" class="block font-medium text-on-surface mb-2">Tarif Cuci Setrika / Kg (Rp)</label>
                            <div class="flex">
                                <span class="inline-flex items-center px-4 py-3 rounded-l-xl border border-r-0 border-outline-variant/50 bg-surface-container-highest text-on-surface-variant font-medium">Rp</span>
                                <input type="number" id="cuci_setrika_price_per_kg" name="cuci_setrika_price_per_kg" value="<%= settings.cuci_setrika_price_per_kg || 0 %>" class="w-full px-4 py-3 rounded-r-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Informasi Pembayaran -->
                <div>
                    <h5 class="text-lg font-bold text-primary border-b border-outline-variant/30 pb-3 mb-6">Informasi Pembayaran (Transfer/QRIS)</h5>
                    
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-6">
                        <div class="md:col-span-4">
                            <label for="bank_name" class="block font-medium text-on-surface mb-2">Nama Bank</label>
                            <input type="text" id="bank_name" name="bank_name" value="<%= settings.bank_name %>" placeholder="Contoh: BCA / Mandiri" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
                        </div>
                        <div class="md:col-span-8">
                            <label for="bank_account_number" class="block font-medium text-on-surface mb-2">Nomor Rekening</label>
                            <input type="text" id="bank_account_number" name="bank_account_number" value="<%= settings.bank_account_number %>" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
                        </div>
                    </div>
                    
                    <div class="mb-6">
                        <label for="bank_account_name" class="block font-medium text-on-surface mb-2">Atas Nama (Pemilik Rekening)</label>
                        <input type="text" id="bank_account_name" name="bank_account_name" value="<%= settings.bank_account_name %>" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
                    </div>

                    <div>
                        <label for="qris_image" class="block font-medium text-on-surface mb-2">Upload QRIS <span class="text-on-surface-variant font-normal">(Opsional)</span></label>
                        <input type="file" id="qris_image" name="qris_image" accept="image/*" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary-container file:text-on-primary-container hover:file:bg-primary-container/80">
                        <p class="text-xs text-on-surface-variant mt-2">Upload gambar QRIS terbaru Anda. Maksimal 5MB.</p>
                        
                        <% if (settings.qris_image_url) { %>
                            <div class="mt-4 bg-surface-container-low p-4 rounded-xl border border-outline-variant/20 inline-block">
                                <p class="text-xs font-semibold text-on-surface-variant mb-3 uppercase tracking-wider">QRIS Saat Ini:</p>
                                <img src="<%= settings.qris_image_url %>" alt="QRIS" class="max-h-48 rounded-lg shadow-sm border border-outline-variant/30">
                            </div>
                        <% } %>
                    </div>
                </div>

                <div class="pt-6 border-t border-outline-variant/30">
                    <button type="submit" class="w-full px-8 py-4 rounded-xl bg-primary text-on-primary font-bold shadow-md hover:bg-primary/90 transition-colors flex items-center justify-center gap-2 text-lg">
                        <span class="material-symbols-outlined">save</span> Simpan Pengaturan
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
