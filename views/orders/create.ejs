<div class="max-w-3xl mx-auto">
  <form action="/orders" method="POST" data-loading class="flex flex-col gap-6">

    <!-- Section 1: Customer -->
    <div class="bg-surface-container-lowest p-6 rounded-2xl shadow-sm border border-outline-variant/30">
      <div class="flex items-center gap-2 text-primary font-bold text-lg mb-6 pb-4 border-b border-outline-variant/30">
        <span class="material-symbols-outlined">account_circle</span>
        <span>Informasi Customer</span>
      </div>

      <!-- Toggle: Customer Baru -->
      <div class="flex items-center gap-3 mb-6">
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="newCustomerToggle" name="is_new_customer" value="1" class="sr-only peer">
          <div class="w-11 h-6 bg-surface-container-highest peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
          <span class="ml-3 font-semibold text-on-surface">Customer Baru</span>
        </label>
      </div>

      <!-- Existing Customer -->
      <div id="existingCustomerField">
        <div class="mb-4">
          <label for="customer_id" class="block text-sm font-medium text-on-surface mb-2">Pilih Customer</label>
          <input type="text" id="customerSearch" list="customerList" placeholder="Ketik nama atau nomor HP..." autocomplete="off" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
          <datalist id="customerList">
            <% if (typeof customers !== 'undefined') { %>
              <% customers.forEach(function(c) { %>
                <option value="<%= c.name %> — <%= c.phone_number %>" data-id="<%= c.id %>">
              <% }); %>
            <% } %>
          </datalist>
          <input type="hidden" name="customer_id" id="customer_id">
          <p class="text-xs text-on-surface-variant mt-2">Mulai ketik nama atau nomor HP untuk mencari.</p>
        </div>
      </div>

      <!-- New Customer Fields -->
      <div id="newCustomerFields" style="display:none;">
        <div class="mb-4">
          <label for="customer_name" class="block text-sm font-medium text-on-surface mb-2">Nama Customer <span class="text-error">*</span></label>
          <input type="text" id="customer_name" name="customer_name" placeholder="Nama lengkap" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
        </div>
        <div class="mb-4">
          <label for="customer_phone" class="block text-sm font-medium text-on-surface mb-2">Nomor WhatsApp <span class="text-error">*</span></label>
          <div class="flex">
            <span class="inline-flex items-center px-4 py-3 rounded-l-xl border border-r-0 border-outline-variant/50 bg-surface-container-highest text-on-surface-variant text-sm">+62</span>
            <input type="tel" id="customer_phone" name="customer_phone" placeholder="8xxxxxxxxxx" class="w-full px-4 py-3 rounded-r-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
          </div>
          <p class="text-xs text-on-surface-variant mt-2">Contoh: 81234567890 (tanpa angka 0 di depan)</p>
        </div>
        <div>
          <label for="customer_address" class="block text-sm font-medium text-on-surface mb-2">Alamat <span class="text-on-surface-variant font-normal">(opsional)</span></label>
          <input type="text" id="customer_address" name="customer_address" placeholder="Alamat customer" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
        </div>
      </div>
    </div>

    <!-- Section 2: Detail Pesanan -->
    <div class="bg-surface-container-lowest p-6 rounded-2xl shadow-sm border border-outline-variant/30">
      <div class="flex items-center gap-2 text-primary font-bold text-lg mb-6 pb-4 border-b border-outline-variant/30">
        <span class="material-symbols-outlined">receipt</span>
        <span>Detail Pesanan</span>
      </div>

      <!-- Jenis Layanan -->
      <div class="mb-6">
        <label class="block text-sm font-medium text-on-surface mb-3">Jenis Layanan <span class="text-error">*</span></label>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <!-- Reguler -->
          <div class="relative">
            <input type="radio" name="service_type" value="reguler" id="serviceReguler" class="peer sr-only" checked>
            <label for="serviceReguler" class="flex items-center gap-4 p-4 rounded-xl border-2 border-outline-variant/30 cursor-pointer peer-checked:border-primary peer-checked:bg-primary-fixed/30 hover:bg-surface transition-colors">
              <div class="w-12 h-12 rounded-full bg-secondary-container text-on-secondary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined">schedule</span>
              </div>
              <div>
                <div class="font-bold text-on-surface">Reguler</div>
                <div class="text-sm text-on-surface-variant mt-1">
                  <% if (typeof settings !== 'undefined' && settings.price_per_kg) { %>
                    Rp <%= Number(settings.price_per_kg).toLocaleString('id-ID') %>/kg
                  <% } else { %>
                    Tarif normal
                  <% } %>
                </div>
              </div>
            </label>
          </div>
          <!-- Express -->
          <div class="relative">
            <input type="radio" name="service_type" value="express" id="serviceExpress" class="peer sr-only">
            <label for="serviceExpress" class="flex items-center gap-4 p-4 rounded-xl border-2 border-outline-variant/30 cursor-pointer peer-checked:border-error peer-checked:bg-error-container/30 hover:bg-surface transition-colors">
              <div class="w-12 h-12 rounded-full bg-error-container text-error flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined">bolt</span>
              </div>
              <div>
                <div class="font-bold text-on-surface">Express</div>
                <div class="text-sm text-on-surface-variant mt-1">
                  <% if (typeof settings !== 'undefined' && settings.express_price_per_kg) { %>
                    Rp <%= Number(settings.express_price_per_kg).toLocaleString('id-ID') %>/kg
                  <% } else { %>
                    Tarif express
                  <% } %>
                </div>
              </div>
            </label>
          </div>
          <!-- Cuci Saja -->
          <div class="relative">
            <input type="radio" name="service_type" value="cuci" id="serviceCuci" class="peer sr-only">
            <label for="serviceCuci" class="flex items-center gap-4 p-4 rounded-xl border-2 border-outline-variant/30 cursor-pointer peer-checked:border-primary peer-checked:bg-primary-fixed/30 hover:bg-surface transition-colors">
              <div class="w-12 h-12 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined">water_drop</span>
              </div>
              <div>
                <div class="font-bold text-on-surface">Cuci</div>
                <div class="text-sm text-on-surface-variant mt-1">
                  <% if (typeof settings !== 'undefined' && settings.cuci_price_per_kg) { %>
                    Rp <%= Number(settings.cuci_price_per_kg).toLocaleString('id-ID') %>/kg
                  <% } else { %>
                    Tarif Cuci
                  <% } %>
                </div>
              </div>
            </label>
          </div>
          <!-- Cuci Kering -->
          <div class="relative">
            <input type="radio" name="service_type" value="cuci_kering" id="serviceCuciKering" class="peer sr-only">
            <label for="serviceCuciKering" class="flex items-center gap-4 p-4 rounded-xl border-2 border-outline-variant/30 cursor-pointer peer-checked:border-primary peer-checked:bg-primary-fixed/30 hover:bg-surface transition-colors">
              <div class="w-12 h-12 rounded-full bg-tertiary-container text-on-tertiary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined">air</span>
              </div>
              <div>
                <div class="font-bold text-on-surface">Cuci Kering</div>
                <div class="text-sm text-on-surface-variant mt-1">
                  <% if (typeof settings !== 'undefined' && settings.cuci_kering_price_per_kg) { %>
                    Rp <%= Number(settings.cuci_kering_price_per_kg).toLocaleString('id-ID') %>/kg
                  <% } else { %>
                    Tarif Cuci Kering
                  <% } %>
                </div>
              </div>
            </label>
          </div>
          <!-- Cuci Setrika -->
          <div class="relative">
            <input type="radio" name="service_type" value="cuci_setrika" id="serviceCuciSetrika" class="peer sr-only">
            <label for="serviceCuciSetrika" class="flex items-center gap-4 p-4 rounded-xl border-2 border-outline-variant/30 cursor-pointer peer-checked:border-primary peer-checked:bg-primary-fixed/30 hover:bg-surface transition-colors">
              <div class="w-12 h-12 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined">iron</span>
              </div>
              <div>
                <div class="font-bold text-on-surface">Cuci Setrika</div>
                <div class="text-sm text-on-surface-variant mt-1">
                  <% if (typeof settings !== 'undefined' && settings.cuci_setrika_price_per_kg) { %>
                    Rp <%= Number(settings.cuci_setrika_price_per_kg).toLocaleString('id-ID') %>/kg
                  <% } else { %>
                    Tarif Cuci Setrika
                  <% } %>
                </div>
              </div>
            </label>
          </div>
        </div>
      </div>

      <!-- Estimasi Berat -->
      <div class="mb-6">
        <label for="weight_estimate" class="block text-sm font-medium text-on-surface mb-2">Estimasi Berat <span class="text-on-surface-variant font-normal">(opsional)</span></label>
        <div class="flex">
          <input type="number" id="weight_estimate" name="weight_estimate" step="0.1" min="0" placeholder="0.0" class="w-full px-4 py-3 rounded-l-xl border border-r-0 border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface">
          <span class="inline-flex items-center px-4 py-3 rounded-r-xl border border-outline-variant/50 bg-surface-container-highest text-on-surface-variant text-sm">kg</span>
        </div>
        <p class="text-xs text-on-surface-variant mt-2">Berat aktual akan diinput saat pesanan selesai dicuci.</p>
      </div>

      <!-- Catatan -->
      <div>
        <label for="notes" class="block text-sm font-medium text-on-surface mb-2">Catatan <span class="text-on-surface-variant font-normal">(opsional)</span></label>
        <textarea id="notes" name="notes" rows="3" placeholder="Misal: pakaian putih pisahkan, ada noda di kemeja, dll." class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface"></textarea>
      </div>
    </div>

    <!-- Submit -->
    <div class="flex flex-col-reverse sm:flex-row justify-between items-center gap-4 mt-2">
      <a href="/orders" class="w-full sm:w-auto px-6 py-3 rounded-xl border border-outline-variant font-semibold text-on-surface hover:bg-surface-container-highest transition-colors flex items-center justify-center gap-2">
        <span class="material-symbols-outlined">arrow_back</span>
        Kembali
      </a>
      <button type="submit" class="w-full sm:w-auto px-8 py-3 rounded-xl bg-primary text-on-primary font-bold shadow-md hover:bg-primary/90 transition-colors flex items-center justify-center gap-2">
        <span class="material-symbols-outlined">check_circle</span>
        Simpan Pesanan
      </button>
    </div>
  </form>
</div>

<script>
  // Customer search → set hidden customer_id
  document.getElementById('customerSearch')?.addEventListener('input', function () {
    const datalist = document.getElementById('customerList');
    const options = datalist.querySelectorAll('option');
    const hiddenInput = document.getElementById('customer_id');
    let found = false;
    options.forEach(function (opt) {
      if (opt.value === document.getElementById('customerSearch').value) {
        hiddenInput.value = opt.dataset.id;
        found = true;
      }
    });
    if (!found) hiddenInput.value = '';
  });

  // Toggle fields
  document.getElementById('newCustomerToggle')?.addEventListener('change', function() {
    const existingField = document.getElementById('existingCustomerField');
    const newFields = document.getElementById('newCustomerFields');
    if(this.checked) {
      existingField.style.display = 'none';
      newFields.style.display = 'block';
    } else {
      existingField.style.display = 'block';
      newFields.style.display = 'none';
    }
  });
</script>
