<div class="py-4">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <h1 class="text-2xl font-bold text-on-surface">Detail Pesanan #<%= order.order_code %></h1>
        <a href="/orders" class="px-5 py-2.5 rounded-xl border border-outline-variant text-on-surface font-semibold hover:bg-surface-container-highest transition-colors flex items-center gap-2">
            <span class="material-symbols-outlined">arrow_back</span> Kembali
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <!-- Order Info -->
        <div class="lg:col-span-7">
            <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/30 h-full flex flex-col">
                <div class="p-6 pb-0">
                    <h5 class="text-lg font-bold text-on-surface mb-0">Informasi Pesanan</h5>
                </div>
                <div class="p-6 flex-1 flex flex-col">
                    <div class="mb-6">
                        <% if (order.status === 'menunggu') { %>
                            <span class="inline-flex items-center px-4 py-2 rounded-lg bg-[#fff8e1] text-[#f57f17] font-semibold text-sm">Menunggu</span>
                        <% } else if (order.status === 'diproses') { %>
                            <span class="inline-flex items-center px-4 py-2 rounded-lg bg-primary-container text-on-primary-container font-semibold text-sm">Diproses</span>
                        <% } else if (order.status === 'selesai') { %>
                            <span class="inline-flex items-center px-4 py-2 rounded-lg bg-[#e8f5e9] text-[#2e7d32] font-semibold text-sm">Selesai</span>
                        <% } else if (order.status === 'diambil') { %>
                            <span class="inline-flex items-center px-4 py-2 rounded-lg bg-surface-container-high text-on-surface font-semibold text-sm">Diambil</span>
                        <% } %>
                    </div>

                    <table class="w-full text-sm">
                        <tbody>
                            <tr class="border-b border-outline-variant/10">
                                <td class="py-3 text-on-surface-variant w-1/3 align-top">Customer</td>
                                <td class="py-3 font-semibold text-on-surface">
                                    <%= order.customer ? order.customer.name : '-' %> 
                                    <div class="text-xs text-on-surface-variant font-normal flex items-center gap-1 mt-1">
                                        <img src="https://cdn-icons-png.flaticon.com/512/124/124034.png" class="w-3 h-3 opacity-50 grayscale" alt="WA"> <%= order.customer ? order.customer.phone_number : '' %>
                                    </div>
                                </td>
                            </tr>
                            <tr class="border-b border-outline-variant/10">
                                <td class="py-3 text-on-surface-variant">Layanan</td>
                                <td class="py-3">
                                    <% const svc = h.getServiceDetails(order.service_type); %>
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md <%= svc.color %> text-xs font-bold uppercase tracking-wider"><%= svc.name %></span>
                                </td>
                            </tr>
                            <tr class="border-b border-outline-variant/10">
                                <td class="py-3 text-on-surface-variant">Berat</td>
                                <td class="py-3 text-on-surface font-medium"><%= order.weight_kg ? order.weight_kg + ' kg' : '-' %></td>
                            </tr>
                            <tr class="border-b border-outline-variant/10">
                                <td class="py-3 text-on-surface-variant">Total Harga</td>
                                <td class="py-3 font-bold text-lg text-primary">
                                    <%= order.price_total ? 'Rp ' + order.price_total.toLocaleString('id-ID') : '-' %>
                                </td>
                            </tr>
                            <tr class="border-b border-outline-variant/10">
                                <td class="py-3 text-on-surface-variant">Catatan</td>
                                <td class="py-3 text-on-surface"><%= order.notes || '-' %></td>
                            </tr>
                            <tr>
                                <td class="py-3 text-on-surface-variant">Dibuat Oleh</td>
                                <td class="py-3 text-on-surface"><%= order.creator ? order.creator.name : '-' %> pada <%= new Date(order.createdAt).toLocaleString('id-ID') %></td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="mt-auto pt-6 border-t border-outline-variant/30">
                        <!-- Action Buttons based on status -->
                        <% if (order.status === 'menunggu') { %>
                            <form action="/orders/<%= order.id %>/process" method="POST" class="w-full">
                                <button type="submit" class="w-full px-6 py-3 rounded-xl bg-primary text-on-primary font-bold shadow-sm hover:bg-primary/90 transition-colors flex items-center justify-center gap-2" onclick="return confirm('Mulai proses pesanan ini?')">
                                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">play_arrow</span> Proses Pesanan
                                </button>
                            </form>
                        <% } else if (order.status === 'diproses') { %>
                            <a href="/orders/<%= order.id %>/complete" class="w-full px-6 py-3 rounded-xl bg-[#2e7d32] text-white font-bold shadow-sm hover:bg-[#1b5e20] transition-colors flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">check_circle</span> Selesaikan & Input Berat
                            </a>
                        <% } else if (order.status === 'selesai' && order.Payment && order.Payment.status === 'paid') { %>
                            <form action="/orders/<%= order.id %>/picked-up" method="POST" class="w-full">
                                <button type="submit" class="w-full px-6 py-3 rounded-xl bg-surface-variant text-on-surface-variant font-bold shadow-sm hover:bg-surface-variant/80 transition-colors flex items-center justify-center gap-2" onclick="return confirm('Tandai pesanan ini sudah diambil customer?')">
                                    <span class="material-symbols-outlined">inventory_2</span> Tandai Sudah Diambil
                                </button>
                            </form>
                        <% } else if (order.status === 'diambil') { %>
                            <div class="bg-surface-container-high text-on-surface rounded-xl p-4 text-center font-medium flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">done_all</span> Pesanan ini sudah selesai dan diambil.
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payment Info -->
        <div class="lg:col-span-5">
            <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/30 h-full flex flex-col">
                <div class="p-6 pb-0">
                    <h5 class="text-lg font-bold text-on-surface mb-0">Informasi Pembayaran</h5>
                </div>
                <div class="p-6 flex-1 flex flex-col">
                    <% if (!order.Payment) { %>
                        <div class="flex flex-col items-center justify-center text-center text-on-surface-variant py-12 flex-1">
                            <span class="material-symbols-outlined text-6xl text-outline-variant mb-4">account_balance_wallet</span>
                            <p class="font-medium">Pembayaran belum ditagihkan.<br><span class="text-sm font-normal">Selesaikan pesanan terlebih dahulu.</span></p>
                        </div>
                    <% } else { %>
                        <div class="mb-6">
                            <% if (order.Payment.status === 'pending') { %>
                                <span class="inline-flex items-center px-4 py-2 rounded-lg bg-[#fff8e1] text-[#f57f17] font-semibold text-sm">Menunggu Pembayaran</span>
                            <% } else { %>
                                <span class="inline-flex items-center px-4 py-2 rounded-lg bg-[#e8f5e9] text-[#2e7d32] font-semibold text-sm">Lunas</span>
                            <% } %>
                        </div>

                        <div class="space-y-4 mb-6">
                            <div class="flex justify-between items-center pb-3 border-b border-outline-variant/10">
                                <span class="text-on-surface-variant text-sm">Metode</span>
                                <span class="uppercase font-bold text-on-surface text-sm"><%= order.Payment.method %></span>
                            </div>
                            <div class="flex justify-between items-center pb-3 border-b border-outline-variant/10">
                                <span class="text-on-surface-variant text-sm">Tagihan Dasar</span>
                                <span class="font-medium text-on-surface text-sm">Rp <%= order.Payment.base_amount.toLocaleString('id-ID') %></span>
                            </div>
                            <% if (order.Payment.method !== 'cash') { %>
                            <div class="flex justify-between items-center pb-3 border-b border-outline-variant/10">
                                <span class="text-on-surface-variant text-sm">Kode Unik</span>
                                <span class="text-[#f57f17] font-bold text-sm">+<%= order.Payment.unique_code %></span>
                            </div>
                            <% } %>
                            <div class="flex justify-between items-center pt-2">
                                <span class="text-on-surface-variant font-bold text-sm">Total Transfer</span>
                                <span class="text-2xl font-bold text-primary">Rp <%= order.Payment.expected_amount.toLocaleString('id-ID') %></span>
                            </div>
                        </div>

                        <div class="mt-auto pt-4">
                            <% if (order.Payment.status === 'pending') { %>
                                <form action="/payments/<%= order.Payment.id %>/approve" method="POST">
                                    <button type="submit" class="w-full px-6 py-3 rounded-xl bg-[#2e7d32] text-white font-bold shadow-sm hover:bg-[#1b5e20] transition-colors flex items-center justify-center gap-2" onclick="return confirm('Apakah Anda yakin dana sudah masuk/diterima?')">
                                        <span class="material-symbols-outlined">done</span> Approve Pembayaran
                                    </button>
                                </form>
                            <% } else { %>
                                <div class="bg-[#e8f5e9] text-[#2e7d32] rounded-xl p-4 flex items-start gap-3">
                                    <span class="material-symbols-outlined mt-0.5" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                    <div class="text-sm">
                                        <p class="font-bold mb-1">Lunas pada <%= new Date(order.Payment.paid_at).toLocaleString('id-ID') %></p>
                                        <p class="opacity-80">Approved by: <%= order.Payment.approver ? order.Payment.approver.name : '-' %></p>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- WA Logs -->
        <div class="lg:col-span-12 mt-2">
            <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/30">
                <div class="p-6 pb-4 border-b border-outline-variant/30">
                    <h5 class="text-lg font-bold text-on-surface mb-0">Log Notifikasi WhatsApp</h5>
                </div>
                <div class="p-0">
                    <% if (!order.WaMessageLogs || order.WaMessageLogs.length === 0) { %>
                        <p class="text-on-surface-variant p-6 mb-0 text-sm">Belum ada notifikasi WhatsApp yang dikirim untuk pesanan ini.</p>
                    <% } else { %>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-sm whitespace-nowrap">
                                <thead class="bg-surface-container-low text-on-surface-variant">
                                    <tr>
                                        <th class="px-6 py-3 font-semibold">Waktu</th>
                                        <th class="px-6 py-3 font-semibold">Tipe</th>
                                        <th class="px-6 py-3 font-semibold w-full">Pesan</th>
                                        <th class="px-6 py-3 font-semibold text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-outline-variant/20">
                                    <% order.WaMessageLogs.forEach(log => { %>
                                        <tr class="hover:bg-surface/50 transition-colors">
                                            <td class="px-6 py-4 text-on-surface-variant text-xs"><%= new Date(log.sent_at).toLocaleString('id-ID') %></td>
                                            <td class="px-6 py-4">
                                                <span class="inline-flex items-center px-2.5 py-1 rounded bg-secondary-container text-on-secondary-container text-xs font-semibold uppercase tracking-wider"><%= log.message_type %></span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="text-on-surface-variant text-xs truncate max-w-xs md:max-w-md lg:max-w-xl" title="<%= log.message_content %>"><%= log.message_content %></div>
                                            </td>
                                            <td class="px-6 py-4 text-center">
                                                <% if (log.status === 'sent') { %>
                                                    <span class="inline-flex items-center px-2.5 py-1 rounded bg-[#e8f5e9] text-[#2e7d32] text-xs font-bold">Terkirim</span>
                                                <% } else { %>
                                                    <span class="inline-flex items-center px-2.5 py-1 rounded bg-error-container text-error text-xs font-bold">Gagal</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
