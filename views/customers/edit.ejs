<div class="py-4 max-w-2xl mx-auto">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-on-surface">Edit Customer</h1>
        <a href="/customers/<%= customer.id %>" class="px-5 py-2.5 rounded-xl border border-outline-variant text-on-surface font-semibold hover:bg-surface-container-highest transition-colors flex items-center gap-2">
            <span class="material-symbols-outlined">arrow_back</span> Kembali
        </a>
    </div>

    <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/30 overflow-hidden">
        <div class="p-6">
            <form action="/customers/<%= customer.id %>" method="POST">
                <div class="mb-5">
                    <label for="name" class="block font-bold text-on-surface mb-2">Nama Customer <span class="text-error">*</span></label>
                    <input type="text" id="name" name="name" required autofocus
                        value="<%= customer.name %>"
                        class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface"
                        placeholder="Masukkan nama customer">
                </div>

                <div class="mb-5">
                    <label for="phone_number" class="block font-bold text-on-surface mb-2">Nomor Telepon / WA <span class="text-error">*</span></label>
                    <div class="flex">
                        <span class="inline-flex items-center px-4 py-3 rounded-l-xl border border-r-0 border-outline-variant/50 bg-surface-container-highest text-on-surface-variant font-medium text-sm">+62</span>
                        <input type="text" id="phone_number" name="phone_number" required
                            value="<%= customer.phone_number %>"
                            class="w-full px-4 py-3 rounded-r-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface"
                            placeholder="8123456789">
                    </div>
                </div>

                <div class="mb-6">
                    <label for="address" class="block font-bold text-on-surface mb-2">Alamat <span class="text-on-surface-variant font-normal">(opsional)</span></label>
                    <textarea id="address" name="address" rows="3"
                        class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface-container-lowest text-on-surface resize-none"
                        placeholder="Masukkan alamat customer"><%= customer.address || '' %></textarea>
                </div>

                <button type="submit" class="w-full px-6 py-4 rounded-xl bg-primary text-on-primary font-bold shadow-md hover:bg-primary/90 transition-colors flex items-center justify-center gap-2 text-lg">
                    <span class="material-symbols-outlined">save</span>
                    Simpan Perubahan
                </button>
            </form>
        </div>
    </div>
</div>
