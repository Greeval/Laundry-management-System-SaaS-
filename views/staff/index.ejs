<div class="py-4 max-w-4xl mx-auto">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-on-surface">Manajemen Staff</h1>
    </div>

    <!-- Tambah Staff Form -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/30 mb-8">
        <div class="p-6">
            <h5 class="text-lg font-bold text-primary border-b border-outline-variant/30 pb-3 mb-6">Tambah Staff Baru</h5>
            <form action="/staff" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block font-medium text-on-surface mb-1">Nama</label>
                    <input type="text" name="name" required class="w-full px-4 py-2 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 bg-surface-container-lowest">
                </div>
                <div>
                    <label class="block font-medium text-on-surface mb-1">Email</label>
                    <input type="email" name="email" required class="w-full px-4 py-2 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 bg-surface-container-lowest">
                </div>
                <div>
                    <label class="block font-medium text-on-surface mb-1">Password</label>
                    <input type="password" name="password" required class="w-full px-4 py-2 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 bg-surface-container-lowest">
                </div>
                <div class="md:col-span-3 flex justify-end">
                    <button type="submit" class="px-6 py-2 rounded-xl bg-primary text-on-primary font-bold shadow-md hover:bg-primary/90">Simpan</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Daftar Staff -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/30">
        <div class="p-6">
            <h5 class="text-lg font-bold text-primary border-b border-outline-variant/30 pb-3 mb-6">Daftar Staff</h5>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-container-low text-on-surface font-semibold border-b border-outline-variant/50">
                            <th class="p-4 rounded-tl-lg">Nama</th>
                            <th class="p-4">Email</th>
                            <th class="p-4 rounded-tr-lg">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/30">
                        <% if (staffList.length === 0) { %>
                            <tr>
                                <td colspan="3" class="p-8 text-center text-on-surface-variant">Belum ada staff terdaftar.</td>
                            </tr>
                        <% } else { %>
                            <% staffList.forEach(staff => { %>
                                <tr class="hover:bg-surface-container-lowest/50 transition-colors">
                                    <td class="p-4 font-medium text-on-surface"><%= staff.name %></td>
                                    <td class="p-4 text-on-surface-variant"><%= staff.email %></td>
                                    <td class="p-4">
                                        <form action="/staff/<%= staff.id %>/delete" method="POST" onsubmit="return confirm('Hapus staff ini?');">
                                            <button type="submit" class="text-error hover:bg-error/10 px-3 py-1 rounded-lg text-sm font-medium transition-colors">Hapus</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
